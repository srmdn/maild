APP_ENV=development
APP_ADDR=:8080
APP_READ_HEADER_TIMEOUT=5s
APP_READ_TIMEOUT=15s
APP_WRITE_TIMEOUT=15s
APP_SHUTDOWN_TIMEOUT=10s
APP_MAX_ATTEMPTS=3
API_KEY_HEADER=X-API-Key
ADMIN_API_KEY=change-me-admin
OPERATOR_API_KEY=change-me-operator
ENCRYPTION_KEY_BASE64=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
RATE_LIMIT_WORKSPACE_PER_HOUR=400
RATE_LIMIT_DOMAIN_PER_HOUR=200
BLOCKED_RECIPIENT_DOMAINS=mailinator.com,tempmail.com
WEBHOOKS_ENABLED=false
WEBHOOK_SIGNING_SECRET=
WEBHOOK_SIGNATURE_HEADER=X-Webhook-Signature
WEBHOOK_TIMESTAMP_HEADER=X-Webhook-Timestamp
WEBHOOK_MAX_SKEW=5m
WEBHOOK_APPLY_MAX_ATTEMPTS=3
AUTO_FAILOVER_ENABLED=true
AUTO_FAILOVER_FAILURE_THRESHOLD=3
AUTO_FAILOVER_WINDOW=5m
AUTO_FAILOVER_COOLDOWN=2m

POSTGRES_DSN=postgres://maild:maild@localhost:5432/maild?sslmode=disable
REDIS_ADDR=localhost:6379
REDIS_DB=0

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@maild.local
