APP_ENV=production
APP_ADDR=:8080
APP_READ_HEADER_TIMEOUT=5s
APP_READ_TIMEOUT=15s
APP_WRITE_TIMEOUT=15s
APP_SHUTDOWN_TIMEOUT=10s
APP_MAX_ATTEMPTS=3
API_KEY_HEADER=X-API-Key
ADMIN_API_KEY=REPLACE_WITH_STRONG_ADMIN_API_KEY
OPERATOR_API_KEY=REPLACE_WITH_STRONG_OPERATOR_API_KEY
ENCRYPTION_KEY_BASE64=REPLACE_WITH_32_BYTE_BASE64_KEY
RATE_LIMIT_WORKSPACE_PER_HOUR=400
RATE_LIMIT_DOMAIN_PER_HOUR=200
BLOCKED_RECIPIENT_DOMAINS=mailinator.com,tempmail.com
WEBHOOKS_ENABLED=true
WEBHOOK_SIGNING_SECRET=REPLACE_WITH_WEBHOOK_SIGNING_SECRET
WEBHOOK_SIGNATURE_HEADER=X-Webhook-Signature
WEBHOOK_TIMESTAMP_HEADER=X-Webhook-Timestamp
WEBHOOK_MAX_SKEW=5m
WEBHOOK_APPLY_MAX_ATTEMPTS=3
AUTO_FAILOVER_ENABLED=true
AUTO_FAILOVER_FAILURE_THRESHOLD=3
AUTO_FAILOVER_WINDOW=5m
AUTO_FAILOVER_COOLDOWN=2m

POSTGRES_DSN=REPLACE_WITH_POSTGRES_DSN_SSLMODE_REQUIRE
REDIS_ADDR=REPLACE_WITH_REDIS_ADDR
REDIS_DB=0

SMTP_HOST=REPLACE_WITH_SMTP_HOST
SMTP_PORT=587
SMTP_USERNAME=REPLACE_WITH_SMTP_USERNAME
SMTP_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
SMTP_FROM=noreply@example.com
