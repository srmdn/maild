#!/usr/bin/env sh
set -eu

COMMIT_MSG_FILE=".git/COMMIT_EDITMSG"

if [ ! -f "$COMMIT_MSG_FILE" ]; then
  exit 0
fi

PATTERN='(Co-authored-by:[[:space:]]*(Claude|ChatGPT)|Generated with Claude Code|Generated by[[:space:]].+)'

if grep -E "$PATTERN" "$COMMIT_MSG_FILE" >/dev/null 2>&1; then
  echo "[pre-commit] Blocked: banned AI attribution line found in commit message."
  echo
  echo "Remove these lines before committing:"
  grep -En "$PATTERN" "$COMMIT_MSG_FILE" | sed 's/^/  /'
  echo
  echo "See docs/AI-COMMIT-CLEANUP.md for cleanup steps."
  exit 1
fi

exit 0
